# Service account used to read the spreadsheet (read-only scope).
# Create one in Google Cloud Console > IAM & Admin > Service Accounts,
# then share your Google Sheet with this email (Viewer access).
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private_key value from the downloaded JSON key file.
# Keep the \n escape sequences as-is (Vercel env vars store it as one line).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# The spreadsheet ID from its URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your-spreadsheet-id

# Name of the tab that holds transactions (matches Tele-Finance Bot's sheet).
SHEET_NAME=Transaksi

# Default reporting cycle settings
NEXT_PUBLIC_DEFAULT_MONTHLY_START_DAY=1

# Auth: JSON map of username -> password (server-side only, never exposed to client)
CREDENTIALS={"admin":"changeme","istri":"changeme"}

# Auth: random secret for signing JWT tokens (min 32 chars, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=replace-with-random-64-hex-chars
